# Dependencies
frontend/node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/

# Build (reconstruit par start.py)
frontend/dist/

# Data utilisateur (chaque instance a sa propre DB)
data/openflow.db
data/openflow.db.backup.*
data/openflow.db.manualbak-*
data/attachments/*
!data/attachments/.gitkeep

# Certificat TLS local (clé privée du serveur https, jamais versionnée)
data/tls/

# Bases SQLite stray (creees par un outil lance depuis un mauvais CWD)
*.db

# Config utilisateur (cree par setup.py depuis config.example.yaml)
config.yaml

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Tests
.pytest_cache/
htmlcov/
.coverage

# Plans d'implementation internes (pas utiles aux utilisateurs)
docs/superpowers/plans/

# Playwright MCP artifacts
.playwright-mcp/

# Audit artifacts
audit/
!audit/.gitkeep

# Brouillons de session (scripts d analyse jetables)
scratchpad/
